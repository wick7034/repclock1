# Supabase (required for global feed and leaderboard)
# 1. Create a project at https://app.supabase.com
# 2. Copy this file to .env.local and fill in the values from Project Settings → API
# 3. Run supabase/schema.sql in the Supabase SQL Editor to create tables and policies
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: set to "true" to skip Supabase (feed/leaderboard will be empty)
# NEXT_PUBLIC_SUPABASE_DISABLED=true
